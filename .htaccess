# =============================================================
# TEXAS QUIMICA - Landing Page revendedor.texasquimica.com.br
# Performance + Security + SEO
# =============================================================

# ----- FORCA HTTPS -----
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# ----- GZIP COMPRESSION -----
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml
  AddOutputFilterByType DEFLATE application/ld+json image/svg+xml font/ttf font/otf
  AddOutputFilterByType DEFLATE application/vnd.ms-fontobject application/font-woff application/font-woff2
</IfModule>

# ----- BROWSER CACHE (Expires) -----
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault                              "access plus 1 month"

  # HTML - curto pra invalidar updates rapido
  ExpiresByType text/html                     "access plus 1 hour"

  # CSS / JS - 1 mes
  ExpiresByType text/css                      "access plus 1 month"
  ExpiresByType application/javascript        "access plus 1 month"
  ExpiresByType text/javascript               "access plus 1 month"

  # Imagens - 1 ano (fingerprintar filename se precisar invalidar)
  ExpiresByType image/jpeg                    "access plus 1 year"
  ExpiresByType image/jpg                     "access plus 1 year"
  ExpiresByType image/png                     "access plus 1 year"
  ExpiresByType image/webp                    "access plus 1 year"
  ExpiresByType image/svg+xml                 "access plus 1 year"
  ExpiresByType image/x-icon                  "access plus 1 year"

  # Fontes - 1 ano
  ExpiresByType font/woff                     "access plus 1 year"
  ExpiresByType font/woff2                    "access plus 1 year"
  ExpiresByType application/font-woff         "access plus 1 year"
  ExpiresByType application/font-woff2        "access plus 1 year"

  # SEO files
  ExpiresByType application/xml               "access plus 1 day"
  ExpiresByType text/xml                      "access plus 1 day"
</IfModule>

# ----- CACHE-CONTROL HEADERS -----
<IfModule mod_headers.c>
  # Imagens, fontes, CSS, JS - immutable (1 ano)
  <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico|woff|woff2|ttf|otf|eot)$">
    Header set Cache-Control "max-age=31536000, public, immutable"
  </FilesMatch>

  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "max-age=2592000, public"
  </FilesMatch>

  # HTML - pouco cache pra updates aparecerem rapido
  <FilesMatch "\.html$">
    Header set Cache-Control "max-age=3600, public, must-revalidate"
  </FilesMatch>

  # ----- SECURITY HEADERS -----
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
</IfModule>

# ----- BLOCK ACCESS TO DEV FILES -----
<FilesMatch "^(\.git|\.gitignore|\.env|package\.json|package-lock\.json|node_modules|MIGRACAO|Code-v2)">
  Require all denied
</FilesMatch>

# Bloqueia acesso a pasta apps-script e docs (nao servem no site)
RedirectMatch 404 /apps-script/.*
RedirectMatch 404 /README\.md$
RedirectMatch 404 /index-v1-backup\.html$

# ----- MIME TYPES -----
<IfModule mod_mime.c>
  AddType application/ld+json                 .jsonld
  AddType image/svg+xml                       .svg .svgz
  AddType image/webp                          .webp
  AddType font/woff                           .woff
  AddType font/woff2                          .woff2
</IfModule>

# ----- DISABLE DIRECTORY LISTING -----
Options -Indexes

# ----- REDIRECT /v2.html -> / (compat depois da promocao) -----
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^v2\.html$ / [R=301,L]
</IfModule>
